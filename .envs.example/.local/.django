# 一般設定
# ------------------------------------------------------------------------------
USE_DOCKER=yes
IPYTHONDIR=/app/.ipython

# データベース設定
# ------------------------------------------------------------------------------
# 注意: .postgresファイルの認証情報と一致させてください
DATABASE_URL=postgresql://debug:debug@postgres:5432/school_diary

# セキュリティ設定
# ------------------------------------------------------------------------------
# 重要: 本番環境では必ずシークレットキーを変更してください
# これは開発環境専用の値です
DJANGO_SECRET_KEY=local-development-secret-key-change-in-production
