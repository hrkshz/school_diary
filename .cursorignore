# Cursor AI Ignore Rules
# AIに読ませる必要のないファイル・ディレクトリを指定

# Python キャッシュ・ビルド成果物
__pycache__/
*.pyc
*.pyo
*.pyd
*.so
*.egg-info/
.Python
build/
dist/
*.egg

# 仮想環境（エディタ用の軽量環境）
.venv/
venv/
env/

# Docker ボリューム・ビルドキャッシュ
# （実行環境はDockerなので、AIに読ませる必要なし）

# データベースファイル
*.sqlite3
*.db

# ログファイル
*.log
logs/

# 静的ファイル・メディア（生成物）
staticfiles/
media/
htmlcov/

# OS固有
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# IDEキャッシュ
.idea/
*.iml

# テストカバレッジレポート
.coverage
.coverage.*
.hypothesis/
.pytest_cache/
.tox/

# Node.js関連（フロントエンド開発時）
node_modules/
npm-debug.log
yarn-error.log

# ロックファイル（内容が膨大）
uv.lock
poetry.lock
package-lock.json
yarn.lock

# 生成されたマイグレーションファイル（多数になりがち）
# ※必要に応じてコメントアウト
# */migrations/0*.py

# ドキュメント生成ツールの出力
docs/_build/
docs/.doctrees/

# 環境変数ファイル（機密情報）
.env
.envs/

# バックアップファイル
*.bak
*.backup
*~

# 大規模なバイナリファイル
*.zip
*.tar.gz
*.tgz
*.rar
*.7z
*.pdf
*.xlsx
*.docx

# Git関連（AIに読ませる必要なし）
.git/
.gitattributes

